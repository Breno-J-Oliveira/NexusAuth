# ============================================
# NexusAuth — Environment Variables (Fase 2)
# ============================================

# SECURITY: NEVER include real secrets in .env files committed to git.
# Use .env.example only with placeholders.
# If real secrets were ever exposed, ROTATE THEM IMMEDIATELY.

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://nexus:change_me_to_a_strong_password@localhost:5432/nexusauth?schema=public

# Redis
REDIS_PASSWORD=change_me_to_a_strong_redis_password
REDIS_URL=redis://:change_me_to_a_strong_redis_password@localhost:6379

# Trust proxy hops (0=direct, 1=nginx/ALB/Cloudflare)
TRUST_PROXY_HOPS=0

# JWT RS256
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nexusauth

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexusauth.local

# OAuth2 — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth2 — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=90

# Encryption key for TOTP secrets (AES-256-GCM, 32-byte hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Security: Maximum login attempts before progressive lockout
MAX_LOGIN_ATTEMPTS=5
# Security: Initial lockout duration (minutes)
LOCKOUT_DURATION_MINUTES=15
# Security: Session timeout (hours)
SESSION_TIMEOUT_HOURS=168
# Security: Maximum request body size
REQUEST_BODY_LIMIT=100kb
# Security: Maximum concurrent sessions per user (1=single-session policy, 999=unlimited)
MAX_CONCURRENT_SESSIONS=999
# Security: Session inactivity timeout (hours)
SESSION_INACTIVITY_HOURS=24
# Security: Require email verification before login (set to false for tests)
REQUIRE_EMAIL_VERIFIED=true

# Redis: Token required to execute FLUSHALL in production
REDIS_FLUSH_TOKEN=

# CSP: Report-only mode (true) or enforcement (false)
CSP_REPORT_ONLY=false
# CSP: Endpoint to receive violation reports
CSP_REPORT_URI=/api/csp-report

# Threat Intelligence: API key for AbuseIPDB (optional)
ABUSEIPDB_API_KEY=
# Threat Intelligence: MaxMind GeoIP2 license key (optional)
MAXMIND_LICENSE_KEY=

# ============================================
# Production-only requirements (validated in env.ts)
# ============================================
# In production, ENCRYPTION_KEY and CORS_ORIGINS are required
