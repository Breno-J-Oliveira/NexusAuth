# ============================================
# NexusAuth — Environment Variables (Fase 1)
# ============================================

# C1 CRITICAL SECURITY NOTE:
# NEVER include real secrets in .env files that are shared or committed.
# The .env file should ALWAYS be in .gitignore.
# Use only .env.example with placeholders like this file.
# If real secrets were ever exposed, ROTATE THEM IMMEDIATELY:
# - POSTGRES_PASSWORD
# - REDIS_PASSWORD
# - ENCRYPTION_KEY (requires migration script for existing 2FA secrets)
# - GOOGLE_CLIENT_SECRET
# - GITHUB_CLIENT_SECRET

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://nexus:change_me_to_a_strong_password@localhost:5432/nexusauth?schema=public

# Redis
REDIS_PASSWORD=change_me_to_a_strong_redis_password
REDIS_URL=redis://:change_me_to_a_strong_redis_password@localhost:6379

# HIGH FIX: Number of trusted proxy hops for rate limiting behind reverse proxy
# Set to 0 for direct exposure (safer default), 1 for nginx/ALB/Cloudflare
TRUST_PROXY_HOPS=0

# JWT RS256
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nexusauth

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# SMTP (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexusauth.local

# OAuth2 — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth2 — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Audit Log
AUDIT_LOG_RETENTION_DAYS=90

# Encryption key for TOTP secrets at rest (AES-256-GCM, 32-byte hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
